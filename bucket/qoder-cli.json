{
    "version": "0.2.13",
    "description": "Qoder CLI - A powerful command-line interface for Qoder AI services.",
    "homepage": "https://qoder.com",
    "license": "MIT",
    "architecture": {
        "64bit": {
            "url": "https://qoder-ide.oss-accelerate.aliyuncs.com/qodercli/releases/0.2.13/qodercli-windows-x64.zip",
            "hash": "dd89347d7b006bf1cec5361445fd4514bb9d3a46e6ba48b60f9bf3185ecea757"
        }
    },
    "bin": "qodercli.exe",
    "checkver": {
        "script": [
            "$json = Invoke-RestMethod -Uri 'https://download.qoder.com/qodercli/channels/manifest.json'",
            "$file = $json.files | Where-Object { $_.os -eq 'windows' -and $_.arch -eq 'amd64' } | Select-Object -First 1",
            "Write-Output \"$($json.latest) $($file.url) $($file.sha256)\""
        ],
        "regex": "(?<version>[\\d.]+)\\s+(?<url>[^\\s]+)\\s+(?<hash>[^\\s]+)"
    },
    "autoupdate": {
        "architecture": {
            "64bit": {
                "url": "$matchUrl",
                "hash": "$matchHash"
            }
        }
    }
}
