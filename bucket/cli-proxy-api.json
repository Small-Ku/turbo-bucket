	"homepage": "https://github.com/router-for-me/CLIProxyAPI",
	"license": "MIT",
	"url": "https://github.com/router-for-me/CLIProxyAPI/releases/download/v7.0.10/CLIProxyAPI_7.0.10_windows_amd64.zip",
	"hash": "90bde28631b5114526a9ee645531c07f0aa343a6a29c197b8b1713f84584a259",
	"bin": [
		[
			"cli-proxy-api.exe",
			"cli-proxy-api",
			"--config $persist_dir\\config\\config.yaml"
		]
	],
	"pre_install": [
		"ensure \"$persist_dir\\config\" | Out-Null",
		"if (!(Test-Path \"$persist_dir\\config\\config.yaml\") -and (Test-Path \"$dir\\config.example.yaml\")) {",
		"Copy-Item \"$dir\\config.example.yaml\" \"$persist_dir\\config\\config.yaml\"",
		"}"
	],
	"persist": "config",
	"checkver": "github",
	"autoupdate": {
		"url": "https://github.com/router-for-me/CLIProxyAPI/releases/download/v$version/CLIProxyAPI_$version_windows_amd64.zip"
	}
}
