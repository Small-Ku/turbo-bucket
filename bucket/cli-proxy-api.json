{
	"version": "7.0.12",
	"description": "Wrap Gemini CLI, Antigravity, ChatGPT Codex, Claude Code, Qwen Code, iFlow as an OpenAI/Gemini/Claude/Codex compatible API service",
	"homepage": "https://github.com/router-for-me/CLIProxyAPI",
	"license": "MIT",
	"url": "https://github.com/router-for-me/CLIProxyAPI/releases/download/v7.0.12/CLIProxyAPI_7.0.12_windows_amd64.zip",
	"hash": "64beec67941b486eda9a27b68230586213dd6084e0b54bd217558b4d86daa183",
	"bin": [
		[
			"cli-proxy-api.exe",
			"cli-proxy-api",
			"--config $persist_dir\\config\\config.yaml"
		]
	],
	"pre_install": [
		"ensure \"$persist_dir\\config\" | Out-Null",
		"if (!(Test-Path \"$persist_dir\\config\\config.yaml\") -and (Test-Path \"$dir\\config.example.yaml\")) {",
		"Copy-Item \"$dir\\config.example.yaml\" \"$persist_dir\\config\\config.yaml\"",
		"}"
	],
	"persist": "config",
	"checkver": "github",
	"autoupdate": {
		"url": "https://github.com/router-for-me/CLIProxyAPI/releases/download/v$version/CLIProxyAPI_$version_windows_amd64.zip"
	}
}
